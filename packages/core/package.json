{
  "name": "@ts.app/core",
  "version": "0.0.16",
  "description": "",
  "scripts": {
    "build": "tsc -p ./tsconfig.json && next build ./appdata/next/ && tailwindcss -c ./tailwind/config.js -i ./tailwind/input.css -o ./next/public/ts.css --minify",
    "tsc:watch": "tsc -w -p ./tsconfig.json",
    "css:watch": "tailwindcss -c ./tailwind/config.js -i ./tailwind/input.css -o ./next/public/ts.css --watch",
    "test": "vitest",
    "test:setup": "vitest ./common/test",
    "test:service": "vitest ./common/service/service.test.ts",
    "test:access": "vitest ./models/user/access",
    "test:job-template": "vitest ./jobs/template",
    "test:job-campaign": "vitest ./jobs/campaign"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/typestackapp/ts.app.git"
  },
  "bin": {
    "ts": "dist/esm/common/cli/cli.js"
  },
  "type": "module",
  "module": "dist/esm/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js"
    },
    "./*": {
      "types": "./dist/types/*",
      "import": "./dist/esm/*"
    },
    "./codegen/*": {
      "types": "./codegen/*",
      "import": "./codegen/*"
    },
    "./appdata/*": {
      "types": "./appdata/*",
      "import": "./appdata/*"
    }
  },
  "files": [
    "bin",
    "dist",
    "codegen",
    "docker",
    "haproxy",
    "next",
    "static",
    "appdata/next/.next"
